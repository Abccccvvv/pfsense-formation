yaml
name: CI Pipeline

on:
  push:
    branches: [ main, develop ]
  pull_request:
    branches: [ main, develop ]

jobs:
  lint-and-scan:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v3
      - name: Set up Python (for yamllint)
        uses: actions/setup-python@v4
        with:
          python-version: '3.x'
      - name: ShellCheck
        uses: ludeeus/action-shellcheck@v1
        with:
          args: scripts/**/*.sh
      - name: yamllint
        uses: ibiqlik/action-yamllint@v3
        with:
          files: '**/*.yml'
      - name: Trivy Scan
        uses: aquasecurity/trivy-action@v0.6.0
        with:
          format: 'table'
          exit-code: '1'
          vuln-type: 'os,library'
  tests:
    runs-on: ubuntu-latest
    needs: [lint-and-scan]
    steps:
      - uses: actions/checkout@v3
      - name: Run unit tests (if any)
        run: |
          echo "No unit tests configured yet" || true
  archive-artifacts:
    runs-on: ubuntu-latest
    needs: [tests]
    steps:
      - uses: actions/checkout@v3
      - name: Upload artefacts
        uses: actions/upload-artifact@v3
        with:
          name: docs
          path: docs/
